{
  "name": "tradewhisper-backend",
  "version": "1.0.0",
  "private": true,
  "description": "TradeWhisper backend: on-chain contracts + live MarketAgent for HashKey testnet",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "dev": "npm run agent:dev",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network hashkeyTestnet",
    "deploy:assets:testnet": "hardhat run scripts/setupTestnetAssets.ts --network hashkeyTestnet",
    "agent:dev": "tsx src/agent/index.ts",
    "lint": "echo \"No lint config yet\"",
    "test": "hardhat test"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "openai": "^4.56.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "hardhat": "^2.22.12",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
