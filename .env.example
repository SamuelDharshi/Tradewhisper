# Core network
HSK_RPC_URL=https://testnet.hsk.xyz

# Keys
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
MARKET_AGENT_PRIVATE_KEY=0xYOUR_MARKET_AGENT_PRIVATE_KEY
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY
GROQ_API_KEY=gsk_your_groq_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
EVALUATOR_MODEL=llama-3.3-70b-versatile

# Optional deploy-time relayer address override (defaults to deployer if omitted)
RELAYER_ADDRESS=0x0000000000000000000000000000000000000000

# Deployed contract addresses (after deploy)
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TRADE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
ATOMIC_SWAP_ADDRESS=0x0000000000000000000000000000000000000000

# Live token + oracle addresses on HashKey testnet
USDC_ADDRESS=0x0000000000000000000000000000000000000000
HSK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
PRICE_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# Oracle interpretation
# USDC_PER_HSK -> price answers how many USDC for 1 HSK
# HSK_PER_USDC -> price answers how many HSK for 1 USDC
ORACLE_MODE=USDC_PER_HSK

# Market making params
SPREAD_BPS=30
MAX_REQUEST_AGE_SEC=60
MIN_AGENT_REPUTATION=10
FORCE_LOCAL_AI=false
BACKEND_PORT=3000
# Render sets PORT automatically at runtime. Keep this only for local fallback/testing.
PORT=3000
